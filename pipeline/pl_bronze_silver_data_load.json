							"pDsDatabaseName": {
								"value": "@pipeline().parameters.pPlDatabaseName",
								"type": "Expression"
							},
							"pDsSchemaName": {
								"value": "@pipeline().parameters.pPlSchemaName",
								"type": "Expression"
							},
							"pDsTableName": {
								"value": "@pipeline().parameters.pPlTableName",
								"type": "Expression"
							}
						}
					},
					"firstRowOnly": false
				}
			}
		],
		"parameters": {
			"pPlServerName": {
				"type": "string",
