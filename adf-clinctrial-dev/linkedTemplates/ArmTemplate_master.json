{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-clinctrial-dev"
		},
		"ls_adls_gen_2_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_adls_gen_2'"
		},
		"ls_azuresql_clintrial_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_azuresql_clintrial'"
		},
		"ls_sqlserver_healthconnect_raw_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_sqlserver_healthconnect_raw'"
		},
		"ls_adls_gen_2_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://stclinctraildev.dfs.core.windows.net/"
		},
		"ls_azuresql_clintrial_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sql-clinctrial-dev.database.windows.net"
		},
		"ls_azuresql_clintrial_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sqldb-clintrial-dev"
		},
		"ls_azuresql_clintrial_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "CloudSAa089d679"
		},
		"ls_sqlserver_healthconnect_raw_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "localhost\\SQLEXPRESS"
		},
		"ls_sqlserver_healthconnect_raw_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "dev_Healthconnect_raw"
		},
		"ls_sqlserver_healthconnect_raw_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "DESKTOP-LR9UMUI\\Priti"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-clinctrial-dev_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_adls_gen_2_accountKey": {
						"value": "[parameters('ls_adls_gen_2_accountKey')]"
					},
					"ls_azuresql_clintrial_password": {
						"value": "[parameters('ls_azuresql_clintrial_password')]"
					},
					"ls_sqlserver_healthconnect_raw_password": {
						"value": "[parameters('ls_sqlserver_healthconnect_raw_password')]"
					},
					"ls_adls_gen_2_properties_typeProperties_url": {
						"value": "[parameters('ls_adls_gen_2_properties_typeProperties_url')]"
					},
					"ls_azuresql_clintrial_properties_typeProperties_server": {
						"value": "[parameters('ls_azuresql_clintrial_properties_typeProperties_server')]"
					},
					"ls_azuresql_clintrial_properties_typeProperties_database": {
						"value": "[parameters('ls_azuresql_clintrial_properties_typeProperties_database')]"
					},
					"ls_azuresql_clintrial_properties_typeProperties_userName": {
						"value": "[parameters('ls_azuresql_clintrial_properties_typeProperties_userName')]"
					},
					"ls_sqlserver_healthconnect_raw_properties_typeProperties_server": {
						"value": "[parameters('ls_sqlserver_healthconnect_raw_properties_typeProperties_server')]"
					},
					"ls_sqlserver_healthconnect_raw_properties_typeProperties_database": {
						"value": "[parameters('ls_sqlserver_healthconnect_raw_properties_typeProperties_database')]"
					},
					"ls_sqlserver_healthconnect_raw_properties_typeProperties_userName": {
						"value": "[parameters('ls_sqlserver_healthconnect_raw_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}